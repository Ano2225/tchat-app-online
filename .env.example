# ─────────────────────────────────────────────────────────────────────────────
# BabiChat Online — Environment Variables
# Copy to .env and fill in all values before starting.
# Generate secrets with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Required — server will refuse to start without these ─────────────────────
MONGODB_URI=mongodb://babichat:CHANGE_ME@localhost:27017/babichat?authSource=admin
BETTER_AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
CSRF_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
FRONTEND_URL=http://localhost:3000

# ── MongoDB credentials (used by docker-compose) ─────────────────────────────
MONGO_ROOT_USER=babichat
MONGO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_16

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
BACKEND_URL=http://localhost:8000
BETTER_AUTH_URL=http://localhost:8000/api/auth

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_16
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── File uploads (Cloudinary) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Dev: leave blank to use Mailhog (docker-compose sets SMTP_HOST=mailhog automatically)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ── AI / Groq (optional — UI hidden in MVP) ───────────────────────────────────
GROQ_API_KEY=

# ── Quiz translation (optional — falls back to MyMemory free API) ─────────────
DEEPL_API_KEY=

# ── Analytics (Umami) ─────────────────────────────────────────────────────────
UMAMI_DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_16
UMAMI_APP_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Admin init script — run once then remove from env ─────────────────────────
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (frontend/.env.local) — public vars, prefixed NEXT_PUBLIC
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Analytics (optional — tracking disabled if not set)
NEXT_PUBLIC_UMAMI_URL=http://localhost:3001
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
