# Development — hot-reload via nodemon
# Build context must be the project ROOT (package.json lives there)
# docker-compose.dev.yml: context: ../ dockerfile: backend/Dockerfile.dev

FROM node:20-alpine
WORKDIR /app

RUN apk add --no-cache dumb-init

# package.json is at project root
COPY package*.json ./
RUN npm install

# Source is mounted as a volume at runtime:
#   - ../backend:/app/backend   (hot-reload)
#   - /app/node_modules         (preserved from image)

ENV NODE_ENV=development

EXPOSE 8000

ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "run", "dev"]
